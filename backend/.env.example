# Copy this file to `.env` in the same folder and fill in the values.
#   cp .env.example .env
#
# No third-party API keys are required — iSpent is fully self-hosted
# (local password hashing + JWT + a local MongoDB). The only secret is
# JWT_SECRET, which you choose yourself (any long random string).

# MongoDB connection string. Local default shown; use your Atlas URI if
# running against a hosted cluster.
MONGODB_URI=mongodb://localhost:27017/ispent-a2

# Secret used to sign JWTs. Replace with a long random string, e.g. the
# output of:  openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# Port the API server listens on.
PORT=3001
